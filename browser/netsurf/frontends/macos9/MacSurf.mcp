</FILELIST>

<!-- ================================================================== -->
<!--  LINK ORDER                                                         -->
<!-- ================================================================== -->
<!--
    Link order: shims first (they provide POSIX symbols), then core
    layers bottom-up, then frontend, then libraries.
-->

<LINKORDER>
    <!-- POSIX Shims -->
    <FILEREF><PATH>shims/mac_iconv.c</PATH></FILEREF>
    <FILEREF><PATH>shims/mac_file_io.c</PATH></FILEREF>
    <FILEREF><PATH>shims/mac_stat.c</PATH></FILEREF>
    <FILEREF><PATH>shims/mac_dirent.c</PATH></FILEREF>
    <FILEREF><PATH>shims/mac_time.c</PATH></FILEREF>

    <!-- libparserutils (tier order: leaf utilities → encodings → codecs → factory → filter → inputstream) -->
    <FILEREF><PATH>../../../../libparserutils/src/utils/errors.c</PATH></FILEREF>
    <FILEREF><PATH>../../../../libparserutils/src/utils/buffer.c</PATH></FILEREF>
    <FILEREF><PATH>../../../../libparserutils/src/utils/stack.c</PATH></FILEREF>
    <FILEREF><PATH>../../../../libparserutils/src/utils/vector.c</PATH></FILEREF>
    <FILEREF><PATH>../../../../libparserutils/src/charset/encodings/utf8.c</PATH></FILEREF>
    <FILEREF><PATH>../../../../libparserutils/src/charset/encodings/utf16.c</PATH></FILEREF>
    <FILEREF><PATH>../../../../libparserutils/src/charset/codecs/codec_ascii.c</PATH></FILEREF>
    <FILEREF><PATH>../../../../libparserutils/src/charset/codecs/codec_8859.c</PATH></FILEREF>
    <FILEREF><PATH>../../../../libparserutils/src/charset/codecs/codec_ext8.c</PATH></FILEREF>
    <FILEREF><PATH>../../../../libparserutils/src/charset/codecs/codec_utf8.c</PATH></FILEREF>
    <FILEREF><PATH>../../../../libparserutils/src/charset/codecs/codec_utf16.c</PATH></FILEREF>
    <FILEREF><PATH>../../../../libparserutils/src/charset/aliases.c</PATH></FILEREF>
    <FILEREF><PATH>../../../../libparserutils/src/charset/codec.c</PATH></FILEREF>
    <FILEREF><PATH>../../../../libparserutils/src/input/filter.c</PATH></FILEREF>
    <FILEREF><PATH>../../../../libparserutils/src/input/inputstream.c</PATH></FILEREF>

    <!-- NetSurf Core Utils -->
    <FILEREF><PATH>../../../utils/utils.c</PATH></FILEREF>
    <FILEREF><PATH>../../../utils/file.c</PATH></FILEREF>
    <FILEREF><PATH>../../../utils/filepath.c</PATH></FILEREF>
    <FILEREF><PATH>../../../utils/log.c</PATH></FILEREF>
    <FILEREF><PATH>../../../utils/time.c</PATH></FILEREF>
    <FILEREF><PATH>../../../utils/nsurl.c</PATH></FILEREF>
    <FILEREF><PATH>../../../utils/url.c</PATH></FILEREF>
    <FILEREF><PATH>../../../utils/utf8.c</PATH></FILEREF>
    <FILEREF><PATH>../../../utils/messages.c</PATH></FILEREF>
    <FILEREF><PATH>../../../utils/nsoption.c</PATH></FILEREF>

    <!-- NetSurf Content -->
    <FILEREF><PATH>../../../content/llcache.c</PATH></FILEREF>
    <FILEREF><PATH>../../../content/fetch.c</PATH></FILEREF>
    <FILEREF><PATH>../../../content/fs_backing_store.c</PATH></FILEREF>
    <FILEREF><PATH>../../../content/content.c</PATH></FILEREF>
    <FILEREF><PATH>../../../content/hlcache.c</PATH></FILEREF>
    <FILEREF><PATH>../../../content/mimesniff.c</PATH></FILEREF>
    <FILEREF><PATH>../../../content/urldb.c</PATH></FILEREF>

    <!-- NetSurf Desktop -->
    <FILEREF><PATH>../../../desktop/browser.c</PATH></FILEREF>
    <FILEREF><PATH>../../../desktop/browser_window.c</PATH></FILEREF>
    <FILEREF><PATH>../../../desktop/netsurf.c</PATH></FILEREF>
    <FILEREF><PATH>../../../desktop/gui_factory.c</PATH></FILEREF>
    <FILEREF><PATH>../../../desktop/plot_style.c</PATH></FILEREF>

