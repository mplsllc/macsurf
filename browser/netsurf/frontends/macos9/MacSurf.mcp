        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>../../../../libparserutils/src/charset/codecs/codec_ext8.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>../../../../libparserutils/src/charset/codecs/codec_utf8.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
