        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>../../../../libparserutils/src/input/filter.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>../../../../libparserutils/src/input/inputstream.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
