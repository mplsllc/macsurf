        <PATHTYPE>Project</PATHTYPE>
        <PATH>../../../utils/log.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>../../../utils/time.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>../../../utils/nsurl.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>../../../utils/url.c</PATH>
