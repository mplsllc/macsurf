        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>../../../utils/messages.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>../../../utils/nsoption.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <!-- ============================================================== -->
    <!--  NetSurf Content                                                -->
    <!-- ============================================================== -->

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>../../../content/llcache.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>../../../content/fetch.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>../../../content/fs_backing_store.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>../../../content/content.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>../../../content/hlcache.c</PATH>
        <FILEKIND>Text</FILEKIND>
