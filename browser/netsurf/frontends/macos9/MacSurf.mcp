<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE PROJECT [
  <!ELEMENT PROJECT (TARGETLIST, TARGETORDER, GROUPLIST, DESIGNLIST?)>
  <!ELEMENT TARGETLIST (TARGET+)>
  <!ELEMENT TARGET (NAME, SETTINGLIST, FILELIST?, LINKORDER?)>
  <!ELEMENT NAME (#PCDATA)>
  <!ELEMENT SETTINGLIST (SETTING+)>
  <!ELEMENT SETTING (NAME, VALUE?)>
  <!ELEMENT VALUE (#PCDATA)>
  <!ELEMENT FILELIST (FILE+)>
  <!ELEMENT FILE (PATHTYPE, PATHROOT?, PATH, FILEKIND?, FILEFLAGS?)>
  <!ELEMENT PATHTYPE (#PCDATA)>
  <!ELEMENT PATHROOT (#PCDATA)>
  <!ELEMENT PATH (#PCDATA)>
  <!ELEMENT FILEKIND (#PCDATA)>
  <!ELEMENT FILEFLAGS (#PCDATA)>
  <!ELEMENT LINKORDER (FILEREF+)>
  <!ELEMENT FILEREF (PATH)>
  <!ELEMENT TARGETORDER (ORDEREDTARGET+)>
  <!ELEMENT ORDEREDTARGET (NAME)>
  <!ELEMENT GROUPLIST (GROUP+)>
  <!ELEMENT GROUP (NAME, (FILEREF | GROUP)*)>
  <!ELEMENT DESIGNLIST EMPTY>
]>

<!--
    MacSurf.mcp — CodeWarrior 8 project file (XML export format)

    Target: MacSurf — Mac OS 9 Carbon application
    CPU: PowerPC
    Compiler: MWC PPC C, C99 mode
    Linker: MW PPC Carbon Linker

    Import into CodeWarrior 8 via File > Import Project...
    Or place alongside source and open directly (CW8 reads XML .mcp).
-->

<PROJECT>

<!-- ================================================================== -->
<!--  TARGET DEFINITIONS                                                 -->
<!-- ================================================================== -->

<TARGETLIST>
<TARGET>
<NAME>MacSurf</NAME>

<SETTINGLIST>

    <!-- ============================================================== -->
    <!--  Target Settings                                                -->
    <!-- ============================================================== -->

    <SETTING>
        <NAME>Linker</NAME>
        <VALUE>MacOS PPC Linker</VALUE>
    </SETTING>

    <SETTING>
        <NAME>PreLinker</NAME>
        <VALUE></VALUE>
    </SETTING>

    <SETTING>
        <NAME>PostLinker</NAME>
        <VALUE>MacOS PPC Linker</VALUE>
    </SETTING>

    <SETTING>
        <NAME>Targetname</NAME>
        <VALUE>MacSurf</VALUE>
    </SETTING>

    <SETTING>
        <NAME>OutputDirectory</NAME>
        <VALUE>:</VALUE>
    </SETTING>

    <!-- ============================================================== -->
    <!--  Target Type — Application                                      -->
    <!-- ============================================================== -->

    <SETTING>
        <NAME>MWProject_PPC_type</NAME>
        <VALUE>Application</VALUE>
    </SETTING>

    <SETTING>
        <NAME>MWProject_PPC_filecreator</NAME>
        <VALUE>MSrf</VALUE>
    </SETTING>

    <SETTING>
        <NAME>MWProject_PPC_filetype</NAME>
        <VALUE>APPL</VALUE>
    </SETTING>

    <SETTING>
        <NAME>MWProject_PPC_outfile</NAME>
        <VALUE>MacSurf</VALUE>
    </SETTING>

    <SETTING>
        <NAME>MWProject_PPC_size</NAME>
        <VALUE>4096</VALUE>
    </SETTING>

    <SETTING>
        <NAME>MWProject_PPC_minsize</NAME>
        <VALUE>2048</VALUE>
    </SETTING>

    <SETTING>
        <NAME>MWProject_PPC_stacksize</NAME>
        <VALUE>256</VALUE>
    </SETTING>

    <!-- ============================================================== -->
    <!--  Processor — PowerPC                                            -->
    <!-- ============================================================== -->

    <SETTING>
        <NAME>MWFrontEnd_C_cplusplus</NAME>
        <VALUE>0</VALUE>
    </SETTING>

    <SETTING>
        <NAME>MWFrontEnd_C_c99</NAME>
        <VALUE>1</VALUE>
    </SETTING>

    <SETTING>
        <NAME>MWFrontEnd_C_prefix_file</NAME>
        <VALUE></VALUE>
    </SETTING>

    <!-- ============================================================== -->
    <!--  Preprocessor Defines                                           -->
    <!-- ============================================================== -->

    <SETTING>
        <NAME>C_CPP_Preprocessor_PrefixText</NAME>
        <VALUE>
#define __MACOS9__               1
#define WITHOUT_DUKTAPE          1
#define NO_IPV6                  1
#define TARGET_API_MAC_CARBON    1
        </VALUE>
    </SETTING>

    <!-- ============================================================== -->
    <!--  Access Paths (Include Paths)                                   -->
    <!-- ============================================================== -->
    <!--
        Order matters. CodeWarrior searches in listed order.
        {Project} = directory containing this .mcp file
        {Compiler} = CodeWarrior installation root
    -->

    <!-- 1. Frontend-local includes (macos9.h, shim headers) -->
    <SETTING>
        <NAME>UserSearchPath</NAME>
        <VALUE>{Project}/include</VALUE>
    </SETTING>

    <!-- 2. NetSurf top-level include/ (libwapcaplet, libcss, etc.) -->
    <SETTING>
        <NAME>UserSearchPath</NAME>
        <VALUE>{Project}/../../../include</VALUE>
    </SETTING>

    <!-- 3. NetSurf source root (for "utils/config.h", "content/...", etc.) -->
    <SETTING>
        <NAME>UserSearchPath</NAME>
        <VALUE>{Project}/../../../</VALUE>
    </SETTING>

    <!-- 4. POSIX shim headers (mac_types.h, mac_inet.h, etc.) -->
    <SETTING>
        <NAME>UserSearchPath</NAME>
        <VALUE>{Project}/shims</VALUE>
    </SETTING>

    <!-- 5. libparserutils public headers -->
    <SETTING>
        <NAME>UserSearchPath</NAME>
        <VALUE>{Project}/../../../../libparserutils/include</VALUE>
    </SETTING>

    <!-- 6. libparserutils internal headers (relative #include "input/filter.h") -->
    <SETTING>
        <NAME>UserSearchPath</NAME>
        <VALUE>{Project}/../../../../libparserutils/src</VALUE>
    </SETTING>

    <!-- 7. Mac OS Universal Headers -->
    <SETTING>
        <NAME>SystemSearchPath</NAME>
        <VALUE>{Compiler}/MacOS Support/Headers/Universal Headers</VALUE>
    </SETTING>

    <!-- 6. MSL shared support (runtime headers) -->
    <SETTING>
        <NAME>SystemSearchPath</NAME>
        <VALUE>{Compiler}/MacOS Support/Libraries/Runtime/Shared Support</VALUE>
    </SETTING>

    <!-- ============================================================== -->
    <!--  Code Generation — PowerPC                                      -->
    <!-- ============================================================== -->

    <SETTING>
        <NAME>MWCodeGen_PPC_structalignment</NAME>
        <VALUE>PPC</VALUE>
    </SETTING>

    <SETTING>
        <NAME>MWCodeGen_PPC_tracealiasing</NAME>
        <VALUE>0</VALUE>
    </SETTING>

    <SETTING>
        <NAME>MWCodeGen_PPC_processor</NAME>
        <VALUE>750</VALUE>
    </SETTING>

    <SETTING>
        <NAME>MWCodeGen_PPC_readonlystrings</NAME>
        <VALUE>1</VALUE>
    </SETTING>

    <SETTING>
        <NAME>MWCodeGen_PPC_profiler</NAME>
        <VALUE>0</VALUE>
    </SETTING>

    <!-- ============================================================== -->
    <!--  Warnings                                                       -->
    <!-- ============================================================== -->

    <SETTING>
        <NAME>MWWarning_C_warn_illpragma</NAME>
        <VALUE>1</VALUE>
    </SETTING>

    <SETTING>
        <NAME>MWWarning_C_warn_emptydecl</NAME>
        <VALUE>1</VALUE>
    </SETTING>

    <SETTING>
        <NAME>MWWarning_C_warn_unusedvar</NAME>
        <VALUE>1</VALUE>
    </SETTING>

    <SETTING>
        <NAME>MWWarning_C_warn_unusedarg</NAME>
        <VALUE>0</VALUE>
    </SETTING>

    <SETTING>
        <NAME>MWWarning_C_warn_extracomma</NAME>
        <VALUE>1</VALUE>
    </SETTING>

    <SETTING>
        <NAME>MWWarning_C_warn_implicitconv</NAME>
        <VALUE>1</VALUE>
    </SETTING>

    <SETTING>
        <NAME>MWWarning_C_pedantic</NAME>
        <VALUE>0</VALUE>
    </SETTING>

    <!-- ============================================================== -->
    <!--  Linker Settings — Carbon                                       -->
    <!-- ============================================================== -->

    <SETTING>
        <NAME>MWLinker_PPC_linksym</NAME>
        <VALUE>1</VALUE>
    </SETTING>

    <SETTING>
        <NAME>MWLinker_PPC_linkdead</NAME>
        <VALUE>1</VALUE>
    </SETTING>

    <SETTING>
        <NAME>MWLinker_PPC_generateMap</NAME>
        <VALUE>0</VALUE>
    </SETTING>

</SETTINGLIST>

<!-- ================================================================== -->
<!--  FILE LIST                                                          -->
<!-- ================================================================== -->

<FILELIST>

    <!-- ============================================================== -->
    <!--  NetSurf Core Utils                                             -->
    <!-- ============================================================== -->

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>../../../utils/utils.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>../../../utils/file.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>../../../utils/filepath.c</PATH>
