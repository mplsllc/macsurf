    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>../../../content/urldb.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <!-- ============================================================== -->
    <!--  NetSurf Desktop                                                -->
    <!-- ============================================================== -->

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>../../../desktop/browser.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>../../../desktop/browser_window.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>../../../desktop/netsurf.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>../../../desktop/gui_factory.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>../../../desktop/plot_style.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <!-- ============================================================== -->
    <!--  MacSurf Frontend                                               -->
    <!-- ============================================================== -->

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>main.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>window.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>macos9_bitmap.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>plotters.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>font.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>macos9_fetch.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>clipboard.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>macos9_utf8.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>macos9_download.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>misc.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>schedule.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <!-- ============================================================== -->
    <!--  POSIX Shims                                                    -->
    <!-- ============================================================== -->

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>shims/mac_iconv.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>shims/mac_file_io.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>shims/mac_stat.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>shims/mac_dirent.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>shims/mac_time.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <!-- ============================================================== -->
    <!--  Libraries                                                      -->
    <!-- ============================================================== -->

    <FILE>
        <PATHTYPE>Compiler</PATHTYPE>
        <PATH>MacOS Support/Libraries/Runtime/Shared Support/MSL C.Carbon.Lib</PATH>
        <FILEKIND>Library</FILEKIND>
        <FILEFLAGS>link</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Compiler</PATHTYPE>
        <PATH>MacOS Support/Libraries/MSL/MSL_C/MSL_Common/Lib/MSL C.Carbon.Lib</PATH>
        <FILEKIND>Library</FILEKIND>
        <FILEFLAGS>link</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>System</PATHTYPE>
        <PATH>CarbonLib</PATH>
        <FILEKIND>Library</FILEKIND>
        <FILEFLAGS>link</FILEFLAGS>
    </FILE>

    <!-- ============================================================== -->
    <!--  libparserutils — 15 .c files in tier order                     -->
    <!-- ============================================================== -->

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>../../../../libparserutils/src/utils/errors.c</PATH>
        <FILEKIND>Text</FILEKIND>
        <FILEFLAGS>compile</FILEFLAGS>
    </FILE>

    <FILE>
        <PATHTYPE>Project</PATHTYPE>
        <PATH>../../../../libparserutils/src/utils/buffer.c</PATH>
        <FILEKIND>Text</FILEKIND>
